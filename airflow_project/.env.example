# Copy this file to .env (gitignored) in this same folder, fill in real values.

# Run `id -u` in your WSL2/Linux terminal and paste the result here. Silences
# a harmless warning on Linux; on Windows Docker Desktop you can typically
# leave the default below as-is.
AIRFLOW_UID=50000

# The SAME three values already in your dbt profiles.yml and Power BI
# connection (Databricks -> SQL Warehouses -> your warehouse -> Connection
# details tab, plus your Personal Access Token).
DBT_DATABRICKS_HOST=your-workspace.cloud.databricks.com
DBT_DATABRICKS_HTTP_PATH=/sql/1.0/warehouses/your-warehouse-id
DBT_DATABRICKS_TOKEN=dapiXXXXXXXXXXXXXXXXXXXXXXXXXXXX
